# ─────────────────────────────────────────────────────────────
#  Lenskart Claire AI — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# Copy this file to `.env` and fill in your keys:
#     cp .env.example .env
#
# `start.sh` sources `.env` automatically if present — no need
# to export anything manually.
#
# Never commit `.env` — add it to .gitignore.
# ─────────────────────────────────────────────────────────────

# Primary LLM key: powers chat, vision, TTS, embeddings.
# Get one at https://aistudio.google.com/app/apikey
# Leave blank to run in demo mode (client-side quiz, face, lens, carousel still work).
GEMINI_API_KEY=

# Optional — AWS Bedrock fallback for /api/quiz-analyze only.
# Used when Gemini is unreachable. Bearer-token auth (not IAM).
BEDROCK_BEARER_TOKEN=

# ── Optional overrides (sensible defaults hardcoded in the backend) ──────────

# Main tool-use model. Do NOT set to gemini-3.* — those IDs 404.
# GEMINI_AGENT_MODEL=gemini-2.5-flash

# RAG embeddings (3072-dim). Falls back to embedding-001 / text-embedding-004.
# GEMINI_EMBED_MODEL=gemini-embedding-2

# Bedrock region + model id (used only if BEDROCK_BEARER_TOKEN is set).
# BEDROCK_REGION=ap-south-1
# BEDROCK_MODEL=apac.anthropic.claude-sonnet-4-20250514-v1:0

# HTTP server listen port.
# PORT=8000

# Legacy — no longer used by the main chat loop. Safe to leave empty.
# ANTHROPIC_API_KEY=
